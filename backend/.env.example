# Archivo de ejemplo para variables de entorno.
# Úsalo como base: copia este archivo a .env y ajusta los valores según tu proyecto.

APP_NAME=Plantilla FastAPI
APP_VERSION=0.1.0
APP_ENV=dev
APP_DESCRIPTION=Plantilla base para equipos que construyen APIs con FastAPI
APP_HOST=127.0.0.1
APP_PORT=8000
DOCS_URL=/docs
OPENAPI_URL=/openapi.json
REDOC_URL=/redoc
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:8500
ACCESS_TOKEN_EXPIRE_MINUTES=30
MOCK_AUTH_USERNAME=api_user
MOCK_AUTH_PASSWORD=change_me
MOCK_AUTH_TOKEN=bootstrap-token